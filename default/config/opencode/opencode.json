{
  "$schema": "https://opencode.ai/config.json",
  "model": "amazon-bedrock/global.anthropic.claude-opus-4-8",
  "share": "disabled",
  "enabled_providers": ["amazon-bedrock", "bedrock-mantle-openai"],
  "provider": {
    "amazon-bedrock": {
      "name": "Amazon Bedrock (Cecelia, us-west-2)",
      "options": {
        "profile": "claude-code-DO-NOT-DELETE",
        "region": "us-west-2"
      },
      "models": {
        "global.anthropic.claude-opus-4-8": {
          "name": "Claude Opus 4.8 (Bedrock, 1M context)",
          "limit": { "context": 1000000, "output": 128000 },
          "options": {
            "thinking": { "type": "adaptive" },
            "effort": "max"
          },
          "variants": {
            "low":    { "thinking": { "type": "adaptive" }, "effort": "low" },
            "medium": { "thinking": { "type": "adaptive" }, "effort": "medium" },
            "high":   { "thinking": { "type": "adaptive" }, "effort": "high" },
            "max":    { "thinking": { "type": "adaptive" }, "effort": "max" }
          }
        }
      }
    },
    "bedrock-mantle-openai": {
      "npm": "@ai-sdk/openai",
      "name": "Bedrock Mantle OpenAI (us-east-2, bearer token)",
      "options": {
        "baseURL": "https://bedrock-mantle.us-east-2.api.aws/openai/v1",
        "apiKey": "{env:AWS_BEARER_TOKEN_BEDROCK}",
        "forceReasoning": true
      },
      "models": {
        "openai.gpt-5.5": {
          "name": "GPT-5.5 (Bedrock Mantle)",
          "limit": { "context": 1000000, "output": 65536 },
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"]
          },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "auto" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "auto" }
          }
        },
        "openai.gpt-5.4": {
          "name": "GPT-5.4 (Bedrock Mantle)",
          "limit": { "context": 400000, "output": 65536 },
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"]
          },
          "variants": {
            "none":   { "reasoningEffort": "none",   "reasoningSummary": "auto" },
            "low":    { "reasoningEffort": "low",    "reasoningSummary": "auto" },
            "medium": { "reasoningEffort": "medium", "reasoningSummary": "auto" },
            "high":   { "reasoningEffort": "high",   "reasoningSummary": "auto" },
            "xhigh":  { "reasoningEffort": "xhigh",  "reasoningSummary": "auto" }
          }
        }
      }
    }
  },
  "mcp": {
    "builder-mcp": {
      "type": "local",
      "command": ["builder-mcp"]
    }
  }
}
